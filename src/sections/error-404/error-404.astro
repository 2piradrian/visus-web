---
import style from "./style.module.css";
import BigTitle from "../../components/big-title/big-title.astro";
import Button from "../../components/button/button.astro";
---

<section class={`${style.container} section`}>
    <div class="delimiter">
        <div class={style.content}>
            <p class={style.errorCode}>404</p>
            <BigTitle 
                subtitle="Oops! Página no encontrada" 
                title="Lo sentimos, no pudimos" 
                accentTitle="encontrar lo que buscabas." 
            />
            <p class={style.description}>
                Parece que la página que estás buscando no existe o ha sido movida. 
                Vuelve al inicio para seguir navegando por nuestras soluciones.
            </p>
            <div class={style.buttons}>
                <Button variant="primary" href="/">Volver al Inicio</Button>
            </div>
        </div>
    </div>
</section>

---
import style from "./style.module.css";
import BigTitle from "../../components/big-title/big-title.astro";
import { Image } from "astro:assets";
import projectImg from "../../assets/images/project.jpg";

const values = [
	{
		title: "Rentabilidad",
		text: "Nos diferenciamos en el servicio que facilitamos.",
	},
	{
		title: "Estrategia",
		text: "Respiramos nuestra visión, misión y valores.",
	},
	{
		title: "Sustentabilidad",
		text: "Somos rentables, amigables al ambiente y socialmente correctos.",
	},
	{
		title: "Respeto",
		text: "Escuchamos y aprendemos de nuestros errores.",
	},
	{
		title: "Honestidad",
		text: "Exitosos en la verdad, frente a cualquier consecuencia.",
	},
	{
		title: "Humanidad",
		text: "No perdemos de vista lo esencial, las personas.",
	},
];
---

<section id="proposito" class={`${style.container} section reveal`}>
	<div class="delimiter">
		<div class={style.subcontainer}>
			<div class={style.visionBox}>
				<span class={style.visionLabel}>Nuestra Visión</span>
				<blockquote class={style.visionText}>
					"Empresas más rentables, sustentables y ágiles"
				</blockquote>
			</div>

			<div class={style.misionSection}>
				<div class={style.misionContent}>
					<BigTitle
						subtitle="Nuestra Misión"
						title="Brindar servicios excelentes"
						accentTitle="y respetuosos"
					/>
					<div class={style.misionDescription}>
						<p>
							Ayudamos a las organizaciones a entender la economía sustentable y a
							como medir para tomar mejores decisiones. Cuestiones esenciales para la
							sustentabilidad.
						</p>
					</div>
				</div>
				<div class={style.imageWrapper}>
					<Image
						src={projectImg}
						alt="Gestión estratégica de proyectos"
						class={style.image}
					/>
				</div>
			</div>

			<div class={style.valuesSection}>
				<BigTitle subtitle="Nuestros Valores" title="Lo que nos" accentTitle="impulsa" />
				<div class={style.valuesGrid}>
					{
						values.map((value) => (
							<div class={style.valueCard}>
								<h3 class={style.valueTitle}>{value.title}</h3>
								<p class={style.valueText}>{value.text}</p>
							</div>
						))
					}
				</div>
			</div>
		</div>
	</div>
</section>

---
import styles from './style.module.css';

interface Props {
    href?: string;
    variant?: 'primary' | 'secondary';
    className?: string;
}

const { href, variant = 'primary', className = '' } = Astro.props;
const Element = href ? 'a' : 'button';
---

<Element 
    href={href} 
    class:list={[styles.button, styles[variant], className]}
>
    <slot />
</Element>
